{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true
  },
  "watchOptions": {
    "ignored": [
      "dist/**",
      "uploads/**",
      "node_modules/**",
      "**/*.log",
      "**/*.tsbuildinfo"
    ]
  }
}
